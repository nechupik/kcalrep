rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function adminUid() {
      return "irXSByiUKYg9S5g3UXF5xSXHijC3";
    }

    function partnerUid() {
      return "3DXd9soOLnSZj4Axhg7zWPef2lj2";
    }

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid == adminUid();
    }

    function isPartner() {
      return signedIn() && request.auth.uid == partnerUid();
    }

    function isKnownUser() {
      return isAdmin() || isPartner();
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isKnownUser() && (isOwner(userId) || isAdmin());
    }

    function canPartnerReadAdminData(userId) {
      return isPartner() && userId == adminUid();
    }

    match /users/{userId} {
      allow read, write: if isOwnerOrAdmin(userId);
      allow read: if canPartnerReadAdminData(userId);

      match /profile/{profileId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /diary/{diaryId} {
        allow read, write: if isOwnerOrAdmin(userId);
        allow read: if canPartnerReadAdminData(userId);
      }

      match /weight/{weightId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /norm/{normId} {
        allow read, write: if isOwnerOrAdmin(userId);
        allow read: if canPartnerReadAdminData(userId);
      }

      match /activity/{activityId} {
        allow read, write: if isOwnerOrAdmin(userId);
        allow read: if canPartnerReadAdminData(userId);
      }

      match /products/{productId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /recipes/{recipeId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /usage_stats/{statId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /settings/{settingId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /cycles/{cycleId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /daily_survey/{surveyId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /body_composition/{entryId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /metabolic_config/{configId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }
    }

    match /shared_products/{productId} {
      allow read, write: if isKnownUser();
    }

    match /shared_recipes/{recipeId} {
      allow read, write: if isKnownUser();
    }

    match /categories/{categoryId} {
      allow read: if isKnownUser();
      allow create: if isKnownUser()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isKnownUser()
        && (isAdmin() || resource.data.createdBy == request.auth.uid)
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isKnownUser()
        && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }
  }
}
