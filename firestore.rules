rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      // Allow read/write if user is authenticated and is the owner
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Admin can read/write all user data
      allow read, write: if request.auth != null && request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3";
      
      // User profile
      match /profile/{profileId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
      
      // User diary entries
      match /diary/{diaryId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
      
      // User weight entries
      match /weight/{weightId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
      
      // User norm data
      match /norm/{normId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
      
      // User activity data
      match /activity/{activityId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
      
      // User products
      match /products/{productId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
      
      // User recipes
      match /recipes/{recipeId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
      
      // User usage stats
      match /usage_stats/{statId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
      
      // User settings
      match /settings/{settingId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "irXSByiUKYg9S5g3UXF5xSXHijC3");
      }
    }
    
    // Shared products (readable and writable by all authenticated users)
    match /shared_products/{productId} {
      allow read, write: if request.auth != null;
    }
    
    // Shared recipes (readable and writable by all authenticated users)
    match /shared_recipes/{recipeId} {
      allow read, write: if request.auth != null;
    }
  }
}
